{
  "git": { "deploymentEnabled": false },
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.minicrm.hu; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https:; frame-src https://www.google.com https://maps.google.com https://*.minicrm.hu; connect-src 'self' https://*.minicrm.hu; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'self'; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/.well-known/security.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    }
  ],
  "redirects": [
    { "source": "/cookies",                                                              "destination": "/suti-szabalyzat",                              "permanent": true },
    { "source": "/cookies/",                                                             "destination": "/suti-szabalyzat",                              "permanent": true },
    { "source": "/hidraulika_szivattyu_hidromotor_hidraulikus_munkahenger",              "destination": "/hidraulika-szivattyu-hidromotor-munkahenger",  "permanent": true },
    { "source": "/hidraulika_szivattyu_hidromotor_hidraulikus_munkahenger/",             "destination": "/hidraulika-szivattyu-hidromotor-munkahenger",  "permanent": true },
    { "source": "/hidraulika-szivattyu-hiba_hidromotor-hiba_hidraulikus-munkahenger-hiba",  "destination": "/hidraulika-hiba",                          "permanent": true },
    { "source": "/hidraulika-szivattyu-hiba_hidromotor-hiba_hidraulikus-munkahenger-hiba/", "destination": "/hidraulika-hiba",                          "permanent": true },
    { "source": "/hely",                "destination": "/#kapcsolat",      "permanent": true },
    { "source": "/hely/",               "destination": "/#kapcsolat",      "permanent": true },
    { "source": "/kapcsolat",           "destination": "/#kapcsolat",      "permanent": true },
    { "source": "/kapcsolat/",          "destination": "/#kapcsolat",      "permanent": true },
    { "source": "/mivel-foglalkozunk",  "destination": "/#szolgaltatasok", "permanent": true },
    { "source": "/mivel-foglalkozunk/", "destination": "/#szolgaltatasok", "permanent": true },
    { "source": "/futarrendeles",       "destination": "/#folyamat",       "permanent": true },
    { "source": "/futarrendeles/",      "destination": "/#folyamat",       "permanent": true },
    { "source": "/ingyenes-tanacsadas", "destination": "/",                "permanent": true },
    { "source": "/ingyenes-tanacsadas/","destination": "/",                "permanent": true },
    { "source": "/kezdolap",            "destination": "/",                "permanent": true },
    { "source": "/kezdolap/",           "destination": "/",                "permanent": true },
    { "source": "/home",                "destination": "/",                "permanent": true },
    { "source": "/home/",               "destination": "/",                "permanent": true }
  ]
}
